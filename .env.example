# FraudShield — environment variables template.
#
# Copy this file to .env and fill in your own values:  cp .env.example .env
# .env is git-ignored and must never be committed.
#
# These variables are REQUIRED — docker-compose and the Transaction Service have
# no baked-in defaults, so the stack will not start without a .env.
# For local dev, pick any values you like (the compose stack is local-only).
# Do NOT put production secrets in this template file.

# PostgreSQL (docker-compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Transaction Service datasource (override if Postgres runs elsewhere)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=